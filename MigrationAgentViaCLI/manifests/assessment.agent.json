    "input": [
      { "name": "sourcePath", "type": "folder", "required": false },
      { "name": "targetFramework", "type": "select", "options": ["net6.0", "net8.0", "net10.0"] }
    ],
    "logs": { "stream": true },
    "output": ["readinessScore", "complexity", "blockers", "risks", "estimatedEffort"]
  },
  "apiSpec": { "method": "POST", "endpoint": "/agents/assessment/run" },
  "category": "Migration",
  "subCategory": ".NET Migration"
}

